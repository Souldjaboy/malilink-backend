# ============================================================
# MaliLink / Triangle WMS / Hafiya — Backend
# Copier ce fichier vers .env puis remplacer les valeurs.
# NE JAMAIS committer .env (il est dans .gitignore).
# ============================================================

# --- Serveur ---
PORT=5052
NODE_ENV=development

# --- Sécurité (OBLIGATOIRE en production, le serveur refuse de démarrer sans) ---
# Générer chaque secret séparément : openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
# Signature des reçus Wallet — DOIT être différent de JWT_SECRET (Phase 0).
WALLET_RECEIPT_SECRET=CHANGE_ME_openssl_rand_hex_32_DIFFERENT
# Chiffrement au repos des secrets webhooks (AES-256-GCM), 32 octets hex.
# Optionnel : sans clé, les secrets webhooks restent en clair (format "plain").
WALLET_SECRET_ENC_KEY=CHANGE_ME_openssl_rand_hex_32

# --- Base de données PostgreSQL ---
# MaliLink local :
DATABASE_URL=postgresql://malilink_user:CHANGE_ME_MOT_DE_PASSE@localhost:5432/malilink_global
# Triangle WMS :  postgresql://triangle_user:xxx@localhost:5432/triangle_wms
# Hafiya :        postgresql://hafiya_user:xxx@localhost:5432/hafiya_lab

# --- Pool PostgreSQL (Phase 0 — valeurs par défaut sûres si non définies) ---
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000

# --- Rate limiting (optionnel) ---
# Définir pour un rate-limit partagé multi-instances (sinon mémoire locale).
# Nécessite le paquet `redis`. Ex : redis://127.0.0.1:6379
REDIS_URL=

# --- Produit / tenant par défaut ---
DEFAULT_TENANT_ID=malilink

# --- URLs publiques ---
PUBLIC_BASE_URL=https://malilinkglobal.com
FRONTEND_URL=https://malilinkglobal.com
NEXT_PUBLIC_FRONTEND_URL=https://malilinkglobal.com
APP_URL=https://malilinkglobal.com

# --- IA (assistant) ---
OPENROUTER_API_KEY=

# --- Email ---
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- SMS ---
SMS_PROVIDER=sandbox
SMS_API_KEY=
SMS_SENDER=

# --- Support ---
SUPPORT_WHATSAPP_NUMBER=

# --- Connexion sociale ---
SOCIAL_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_AUTH_URL=
INSTAGRAM_TOKEN_URL=
INSTAGRAM_USERINFO_URL=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_AUTH_URL=
TIKTOK_TOKEN_URL=
TIKTOK_USERINFO_URL=

# --- Paiements ---
PAYMENT_SETTINGS_SECRET=
CARD_PROVIDER_PUBLIC_KEY=
CARD_PROVIDER_SECRET_KEY=
ORANGE_MONEY_API_KEY=
MOOV_MONEY_API_KEY=
WAVE_API_KEY=
